# Kopiera till .env och fyll i dina värden

# Screenpipe
SCREENPIPE_API_KEY=din-nyckel-här

# Vilken provider som används som standard
AI_PROVIDER=ollama
AI_MODEL=ministral

# Fyll i om du vill använda molntjänster
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 1minAI — 100+ modeller, 15 000 gratistokens/dag (logga in på sidan dagligen för att få dem)
# Skaffa nyckel: https://app.1min.ai/api?referrer_id=9b12faba-f8a3-49ea-bd25-d8343f1fd965
# Alla modeller:  https://docs.1min.ai/docs/api/chat-with-ai-api?referrer_id=9b12faba-f8a3-49ea-bd25-d8343f1fd965
ONEMINAI_API_KEY=
OPENROUTER_API_KEY=
